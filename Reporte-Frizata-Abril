<!doctype html>
<html lang="es-AR">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Frizata — Reporte Abril 2026 · Dilema Creative</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,600&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
  :root {
    --ink: #0E2A47; --ink-soft: #1B3A5C; --sage: #4FA27E; --sage-deep: #2F7D5E;
    --cream: #F4EFE6; --paper: #FAF6EE; --paper-2: #EFE8D9; --black: #14161A;
    --ash: #6B6257; --line: #D9CFBC; --good: #2F7D5E; --bad: #B23A2B;
    --star: #5BB4D6; --warn: #C97B2B;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { font-family: 'Inter', system-ui, sans-serif; background: var(--paper); color: var(--black); font-size: 15px; line-height: 1.6; -webkit-font-smoothing: antialiased; }

  /* NAV */
  nav { position: sticky; top: 0; z-index: 100; background: var(--ink); display: flex; align-items: center; justify-content: space-between; padding: 0 48px; height: 56px; border-bottom: 1px solid rgba(255,255,255,0.08); }
  .nav-brand { font-family: 'Fraunces', serif; font-size: 18px; font-weight: 700; color: var(--cream); letter-spacing: -0.02em; }
  .nav-brand em { font-style: italic; color: var(--sage); }
  .nav-links { display: flex; gap: 6px; list-style: none; }
  .nav-links a { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(244,239,230,0.55); text-decoration: none; padding: 6px 12px; border-radius: 3px; transition: all .15s; }
  .nav-links a:hover { color: var(--cream); background: rgba(255,255,255,0.06); }
  .nav-tag { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--sage); padding: 4px 10px; border: 1px solid var(--sage); border-radius: 3px; }

  /* HERO */
  .hero { background: var(--paper); padding: 80px 80px 64px; border-bottom: 1px solid var(--line); position: relative; overflow: hidden; }
  .hero::before { content: ''; position: absolute; top: -120px; right: -120px; width: 500px; height: 500px; background: radial-gradient(circle, rgba(79,162,126,0.07) 0%, transparent 70%); pointer-events: none; }
  .hero-kicker { font-family: 'JetBrains Mono', monospace; font-size: 10.5px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ash); margin-bottom: 20px; display: flex; align-items: center; gap: 16px; }
  .hero-kicker::after { content: ''; flex: 1; max-width: 80px; height: 1px; background: var(--line); }
  .hero h1 { font-family: 'Fraunces', serif; font-weight: 500; font-size: clamp(56px, 8vw, 112px); line-height: 0.9; letter-spacing: -0.035em; color: var(--ink); margin-bottom: 28px; }
  .hero h1 em { font-style: italic; color: var(--sage); }
  .hero-sub { font-family: 'Fraunces', serif; font-size: clamp(18px, 2vw, 24px); font-style: italic; color: var(--ash); max-width: 640px; line-height: 1.4; margin-bottom: 48px; }
  .hero-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--line); border: 1px solid var(--line); border-radius: 6px; overflow: hidden; max-width: 880px; }
  .hero-stat { background: var(--paper); padding: 20px 24px; }
  .hero-stat .k { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ash); margin-bottom: 6px; }
  .hero-stat .v { font-family: 'Fraunces', serif; font-size: 28px; font-weight: 600; color: var(--ink); letter-spacing: -0.02em; line-height: 1; }
  .hero-stat .v.good { color: var(--good); }
  .hero-stat .v.star-c { color: var(--star); }
  .hero-stat .delta { font-family: 'JetBrains Mono', monospace; font-size: 10px; margin-top: 4px; color: var(--ash); }
  .hero-stat .delta.up { color: var(--good); }
  .hero-stat .delta.down { color: var(--bad); }

  /* OBJECTIVE TABLE */
  .obj-block { background: var(--paper); border: 1px solid var(--line); border-radius: 6px; overflow: hidden; margin-bottom: 40px; }
  .obj-table { width: 100%; border-collapse: collapse; font-size: 13.5px; }
  .obj-table th { font-family: 'JetBrains Mono', monospace; font-size: 9.5px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ash); text-align: center; padding: 10px 16px; border-bottom: 1px solid var(--line); background: var(--paper-2); }
  .obj-table th:first-child { text-align: left; }
  .obj-table td { padding: 14px 16px; border-bottom: 1px solid var(--line); color: var(--black); text-align: center; vertical-align: middle; font-family: 'JetBrains Mono', monospace; font-size: 13px; }
  .obj-table td:first-child { text-align: left; font-family: 'Inter', sans-serif; font-weight: 600; color: var(--ink); font-size: 13px; }
  .obj-table tr:last-child td { border-bottom: none; background: var(--paper-2); font-weight: 700; }
  .pill-good { display: inline-block; background: rgba(47,125,94,0.12); color: var(--good); border-radius: 3px; padding: 2px 8px; font-size: 11px; font-weight: 700; }
  .pill-bad { display: inline-block; background: rgba(178,58,43,0.10); color: var(--bad); border-radius: 3px; padding: 2px 8px; font-size: 11px; font-weight: 700; }
  .pill-warn { display: inline-block; background: rgba(201,123,43,0.10); color: var(--warn); border-radius: 3px; padding: 2px 8px; font-size: 11px; font-weight: 700; }

  /* SECTIONS */
  section { padding: 72px 80px; border-bottom: 1px solid var(--line); }
  section.dark { background: var(--ink); color: var(--cream); border-bottom-color: rgba(255,255,255,0.08); }
  section.cream { background: var(--cream); }
  section.ink-soft { background: var(--ink-soft); color: var(--cream); border-bottom-color: rgba(255,255,255,0.08); }
  .sec-head { display: flex; align-items: baseline; gap: 20px; margin-bottom: 48px; padding-bottom: 18px; border-bottom: 1px solid currentColor; opacity: 0.95; }
  .sec-head .num { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.12em; opacity: 0.5; }
  .sec-head h2 { font-family: 'Fraunces', serif; font-weight: 500; font-size: clamp(32px, 4vw, 52px); line-height: 0.95; letter-spacing: -0.025em; }
  .sec-head h2 em { font-style: italic; color: var(--sage); }
  .section-lede { font-family: 'Fraunces', serif; font-size: 20px; font-style: italic; color: var(--ash); max-width: 680px; line-height: 1.4; margin-bottom: 36px; }

  /* PLATFORM TOGGLE */
  .platform-tabs { display: flex; gap: 4px; margin-bottom: 40px; background: var(--paper-2); padding: 4px; border-radius: 6px; width: fit-content; border: 1px solid var(--line); }
  .tab-btn { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; padding: 8px 20px; border-radius: 4px; border: none; background: transparent; color: var(--ash); cursor: pointer; transition: all .2s; }
  .tab-btn.active { background: var(--ink); color: var(--cream); }
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  /* METRICS GRID */
  .metrics-row { display: grid; grid-template-columns: repeat(5, 1fr); gap: 16px; margin-bottom: 32px; }
  .metric-card { background: var(--paper); border: 1px solid var(--line); border-radius: 6px; padding: 20px 18px; position: relative; overflow: hidden; }
  .metric-card::before { content: ''; position: absolute; top: 0; left: 0; width: 3px; height: 100%; background: var(--line); }
  .metric-card.accent-green::before { background: var(--sage); }
  .metric-card.accent-blue::before { background: var(--star); }
  .metric-card.accent-good::before { background: var(--good); }
  .metric-card.accent-warn::before { background: var(--warn); }
  .metric-card .label { font-family: 'JetBrains Mono', monospace; font-size: 9.5px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ash); margin-bottom: 8px; }
  .metric-card .value { font-family: 'Fraunces', serif; font-size: 26px; font-weight: 600; letter-spacing: -0.02em; color: var(--ink); line-height: 1; }
  .metric-card .sub { font-size: 11px; color: var(--ash); margin-top: 4px; font-family: 'JetBrains Mono', monospace; }

  /* CAMPAIGN TABLE */
  .table-wrap { background: var(--paper); border: 1px solid var(--line); border-radius: 6px; overflow: hidden; }
  .camp-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .camp-table th { font-family: 'JetBrains Mono', monospace; font-size: 9.5px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ash); text-align: left; padding: 10px 14px; border-bottom: 1px solid var(--line); background: var(--paper-2); }
  .camp-table td { padding: 13px 14px; border-bottom: 1px solid var(--line); color: var(--black); vertical-align: middle; }
  .camp-table tr:last-child td { border-bottom: none; }
  .camp-table tr:hover td { background: rgba(0,0,0,0.015); }
  .camp-name { font-weight: 600; color: var(--ink); font-size: 12.5px; }
  .camp-type { font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ash); margin-top: 2px; }
  .badge { display: inline-block; font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.08em; text-transform: uppercase; padding: 3px 8px; border-radius: 3px; }
  .badge.green { background: rgba(79,162,126,0.12); color: var(--good); }
  .badge.blue { background: rgba(91,180,214,0.12); color: #3a90b0; }
  .badge.warn { background: rgba(201,123,43,0.12); color: var(--warn); }
  .badge.grey { background: var(--paper-2); color: var(--ash); }
  .badge.red { background: rgba(178,58,43,0.10); color: var(--bad); }
  .num-good { color: var(--good); font-weight: 700; }
  .num-warn { color: var(--warn); font-weight: 700; }
  .num-bad { color: var(--bad); }

  /* CHART CONTAINERS */
  .chart-wrap { background: var(--paper); border: 1px solid var(--line); border-radius: 6px; padding: 24px; }
  .chart-wrap.dark-bg { background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.1); }
  .chart-title { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ash); margin-bottom: 16px; }
  .chart-title.light { color: rgba(244,239,230,0.5); }
  .charts-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 32px; }

  /* ROAS BLOCK */
  .roas-block { background: var(--ink); border-radius: 8px; padding: 40px 48px; display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center; margin: 32px 0; position: relative; overflow: hidden; }
  .roas-block::after { content: 'ROAS'; position: absolute; right: -20px; top: 50%; transform: translateY(-50%); font-family: 'Fraunces', serif; font-size: 180px; font-weight: 700; color: rgba(255,255,255,0.03); line-height: 1; pointer-events: none; }
  .roas-number { font-family: 'Fraunces', serif; font-size: 88px; font-weight: 600; line-height: 0.85; letter-spacing: -0.04em; color: var(--sage); }
  .roas-number sup { font-size: 0.38em; vertical-align: top; margin-top: 12px; display: inline-block; color: rgba(79,162,126,0.7); }
  .roas-label { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(244,239,230,0.5); margin-top: 8px; }
  .roas-pair { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 20px; }
  .roas-mini .k { font-family: 'JetBrains Mono', monospace; font-size: 9.5px; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(244,239,230,0.45); margin-bottom: 4px; }
  .roas-mini .v { font-family: 'Fraunces', serif; font-size: 28px; font-weight: 600; color: var(--cream); letter-spacing: -0.02em; }
  .roas-mini .v.sage { color: var(--sage); }
  .roas-desc { font-family: 'Fraunces', serif; font-size: 21px; font-style: italic; line-height: 1.4; color: var(--cream); }
  .roas-desc strong { font-style: normal; color: var(--sage); }

  /* INSIGHTS */
  .insights-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .insight-card { border: 1px solid var(--line); border-radius: 6px; padding: 24px; background: var(--paper); }
  .insight-card .ico { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; padding: 3px 10px; border-radius: 3px; margin-bottom: 14px; display: inline-block; }
  .insight-card.solved .ico { background: rgba(79,162,126,0.1); color: var(--good); }
  .insight-card.focus .ico { background: rgba(91,180,214,0.1); color: #3a90b0; }
  .insight-card.note .ico { background: rgba(201,123,43,0.1); color: var(--warn); }
  .insight-card h4 { font-family: 'Fraunces', serif; font-size: 19px; font-weight: 500; letter-spacing: -0.01em; color: var(--ink); margin-bottom: 8px; line-height: 1.2; }
  .insight-card p { font-size: 13.5px; color: var(--ash); line-height: 1.55; }
  .stat-pill { margin-top: 14px; font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--ink); background: var(--paper-2); border: 1px solid var(--line); border-radius: 3px; padding: 6px 12px; display: inline-block; letter-spacing: 0.06em; }

  /* NEXT STEPS */
  .steps-list { display: flex; flex-direction: column; gap: 1px; background: var(--line); border: 1px solid var(--line); border-radius: 6px; overflow: hidden; }
  .step-item { display: grid; grid-template-columns: 56px 1fr auto; align-items: center; background: var(--paper); padding: 20px 0; }
  .step-num { font-family: 'Fraunces', serif; font-size: 32px; font-weight: 500; color: rgba(14,42,71,0.15); letter-spacing: -0.03em; text-align: center; line-height: 1; }
  .step-body { padding: 0 24px 0 0; }
  .step-body h4 { font-size: 14px; font-weight: 600; color: var(--ink); margin-bottom: 3px; }
  .step-body p { font-size: 13px; color: var(--ash); }
  .step-tag { margin-right: 24px; font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; padding: 4px 10px; border-radius: 3px; white-space: nowrap; }
  .step-tag.meta { background: rgba(24,119,242,0.08); color: #1877F2; }
  .step-tag.google { background: rgba(52,168,83,0.1); color: #1a7a3d; }
  .step-tag.ambos { background: rgba(79,162,126,0.1); color: var(--sage-deep); }

  /* FUTURE */
  .future-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .future-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 6px; padding: 24px; }
  .future-card .num { font-family: 'Fraunces', serif; font-size: 48px; font-weight: 500; color: var(--sage); opacity: 0.4; line-height: 1; margin-bottom: 12px; letter-spacing: -0.03em; }
  .future-card h4 { font-family: 'Fraunces', serif; font-size: 18px; font-weight: 500; color: var(--cream); margin-bottom: 8px; }
  .future-card h4 em { font-style: italic; color: var(--sage); }
  .future-card p { font-size: 13px; color: rgba(244,239,230,0.6); line-height: 1.55; }

  /* TOP ADS */
  .top-ads-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 32px; }

  /* FOOTER */
  footer { background: var(--ink); color: var(--cream); padding: 40px 80px; display: flex; justify-content: space-between; align-items: center; border-top: 1px solid rgba(255,255,255,0.08); }
  .footer-brand { font-family: 'Fraunces', serif; font-size: 22px; font-weight: 700; letter-spacing: -0.02em; }
  .footer-brand em { font-style: italic; color: var(--sage); }
  footer .meta-f { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.1em; color: rgba(244,239,230,0.4); text-align: right; line-height: 1.8; }

  @media (max-width: 900px) {
    nav { padding: 0 20px; } .nav-links { display: none; }
    section, .hero { padding: 48px 24px; }
    footer { padding: 32px 24px; flex-direction: column; gap: 16px; text-align: center; }
    .hero-stats, .metrics-row { grid-template-columns: 1fr 1fr; }
    .charts-grid, .insights-grid, .future-grid, .top-ads-grid { grid-template-columns: 1fr; }
    .roas-block { grid-template-columns: 1fr; padding: 32px; }
    .roas-number { font-size: 64px; }
  }
</style>
</head>
<body>

<nav>
  <div class="nav-brand">Dilema <em>creative</em></div>
  <ul class="nav-links">
    <li><a href="#resumen">Resumen</a></li>
    <li><a href="#objetivos">Objetivos</a></li>
    <li><a href="#plataformas">Campañas</a></li>
    <li><a href="#roas">ROAS</a></li>
    <li><a href="#insights">Insights</a></li>
    <li><a href="#pasos">Mayo</a></li>
  </ul>
  <span class="nav-tag">Frizata · Abril 2026</span>
</nav>

<!-- HERO -->
<div class="hero" id="resumen">
  <div class="hero-kicker">Reporte mensual &nbsp;·&nbsp; Frizata &nbsp;·&nbsp; Abril 2026</div>
  <h1 class="serif" style="font-family:'Fraunces',serif">Abril<br><em>cerró bien.</em></h1>
  <p class="hero-sub">ROAS combinado de 13x, frecuencias resueltas, catálogo saneado. El volumen de pedidos quedó 15% debajo del objetivo — el foco de Mayo está claro.</p>

  <div class="hero-stats">
    <div class="hero-stat">
      <div class="k">Inversión Total</div>
      <div class="v">$24,6M</div>
      <div class="delta">Meta + Google</div>
    </div>
    <div class="hero-stat">
      <div class="k">Revenue Atribuido</div>
      <div class="v good">$321,5M</div>
      <div class="delta up">Meta + Google combinado</div>
    </div>
    <div class="hero-stat">
      <div class="k">ROAS Combinado</div>
      <div class="v star-c">13.06x</div>
      <div class="delta">Por peso invertido</div>
    </div>
    <div class="hero-stat">
      <div class="k">Pedidos Totales</div>
      <div class="v">2.901</div>
      <div class="delta down">–15% vs objetivo (3.425)</div>
    </div>
  </div>
</div>

<!-- OBJETIVOS -->
<section id="objetivos">
  <div class="sec-head">
    <span class="num">00 / OBJETIVOS</span>
    <h2>Budget vs. <em>real.</em></h2>
  </div>
  <p class="section-lede">Cierre del mes contra los objetivos acordados.</p>

  <div class="obj-block">
    <table class="obj-table">
      <thead>
        <tr>
          <th>Métrica</th>
          <th>Objetivo</th>
          <th>Real</th>
          <th>Cumplimiento</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Pedidos Totales</td>
          <td>3.425</td>
          <td>2.901</td>
          <td><span class="pill-bad">–15%</span></td>
        </tr>
        <tr>
          <td>Hunting</td>
          <td>600</td>
          <td>419</td>
          <td><span class="pill-bad">–30%</span></td>
        </tr>
        <tr>
          <td>Farming</td>
          <td>2.825</td>
          <td>2.482</td>
          <td><span class="pill-warn">–12%</span></td>
        </tr>
        <tr>
          <td>Kilos</td>
          <td>24.489</td>
          <td>21.341</td>
          <td><span class="pill-bad">–13%</span></td>
        </tr>
        <tr>
          <td>Inversión Pauta</td>
          <td>$24.300.000</td>
          <td>$24.632.596</td>
          <td><span class="pill-good">+1.4%</span></td>
        </tr>
        <tr>
          <td>ACOS Total</td>
          <td>~6.3%</td>
          <td>7.3%</td>
          <td><span class="pill-warn">+1pp</span></td>
        </tr>
      </tbody>
    </table>
  </div>

  <p style="font-size:13px; color:var(--ash); font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.06em;">* La inversión se ejecutó correctamente. El gap está principalmente en Hunting (–30%), que es el foco de trabajo para Mayo.</p>
</section>

<!-- CAMPAÑAS -->
<section id="plataformas">
  <div class="sec-head">
    <span class="num">01 / CAMPAÑAS</span>
    <h2>Resultados por <em>plataforma.</em></h2>
  </div>
  <p class="section-lede">Desglose de métricas clave por canal. Sin ruido, solo lo que importa.</p>

  <div class="platform-tabs">
    <button class="tab-btn active" onclick="switchTab('meta', this)">Meta Ads</button>
    <button class="tab-btn" onclick="switchTab('google', this)">Google Ads</button>
  </div>

  <!-- META TAB -->
  <div class="tab-panel active" id="tab-meta">
    <div class="metrics-row">
      <div class="metric-card accent-blue">
        <div class="label">Inversión</div>
        <div class="value">$19.292.833</div>
        <div class="sub">78% del total</div>
      </div>
      <div class="metric-card accent-green">
        <div class="label">Revenue Atribuido</div>
        <div class="value">$165.271.200</div>
        <div class="sub">1.252 compras</div>
      </div>
      <div class="metric-card accent-good">
        <div class="label">ROAS Meta</div>
        <div class="value">8.57x</div>
        <div class="sub">CPA: $15.410</div>
      </div>
      <div class="metric-card">
        <div class="label">Alcance</div>
        <div class="value">1.418.170</div>
